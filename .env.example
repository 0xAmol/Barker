# Barker — Environment Variables
# Copy to .env.local and fill in your keys

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Anthropic (Claude API) ──
ANTHROPIC_API_KEY=

# ── Google Places API ──
GOOGLE_PLACES_API_KEY=

# ── Twilio (SMS) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Crossmint (Solana wallets) ──
CROSSMINT_API_KEY=
CROSSMINT_API_URL=https://staging.crossmint.com/api/2022-06-09

# ── Solana ──
SOLANA_RPC_URL=https://api.devnet.solana.com
PLATFORM_TREASURY_WALLET=

# ── Facebook Graph API ──
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Stripe (credit purchases) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Cron ──
CRON_SECRET=
